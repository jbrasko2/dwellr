{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "watchOptions": {
        "watchFile": "fixedPollingInterval",
        "watchDirectory": "fixedPollingInterval",
        "fallbackPolling": "fixedPollingInterval"
    },
    "exclude": ["node_modules", "dist"]
}
