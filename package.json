{
    "name": "dwellr",
    "private": true,
    "type": "module",
    "workspaces": [
        "src/client",
        "src/server"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev --workspace=src/client\" \"npm run dev --workspace=src/server\" \"npm run codegen:watch\"",
        "dev:client": "npm run dev --workspace=src/client",
        "dev:server": "npm run dev --workspace=src/server",
        "codegen": "graphql-codegen --config codegen.ts",
        "codegen:watch": "graphql-codegen --config codegen.ts --watch",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "npm run test --workspaces --if-present"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@graphql-codegen/cli": "^7.0.0",
        "@graphql-codegen/typescript": "^6.0.0",
        "@graphql-codegen/typescript-operations": "^6.0.0",
        "@graphql-codegen/typescript-resolvers": "^6.0.0",
        "@types/jest": "^30.0.0",
        "concurrently": "^8.2.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.3",
        "typescript-eslint": "^8.59.2"
    }
}