{
    "name": "dwellr",
    "private": true,
    "workspaces": [
        "src/client",
        "src/server"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev --workspace=src/client\" \"npm run dev --workspace=src/server\"",
        "dev:client": "npm run dev --workspace=src/client",
        "dev:server": "npm run dev --workspace=src/server"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "concurrently": "^8.2.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.3",
        "typescript-eslint": "^8.59.2"
    }
}