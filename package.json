{
    "name": "dwellr",
    "private": true,
    "type": "module",
    "workspaces": [
        "src/client",
        "src/server"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev --workspace=src/client\" \"npm run dev --workspace=src/server\" \"npm run codegen:watch\"",
        "dev:client": "npm run dev --workspace=src/client",
        "dev:server": "npm run dev --workspace=src/server",
        "codegen": "graphql-codegen --config codegen.ts",
        "codegen:watch": "graphql-codegen --config codegen.ts --watch",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "npm run test --workspaces --if-present"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@graphql-codegen/cli": "^7.0.0",
        "@graphql-codegen/typescript": "^6.0.0",
        "@graphql-codegen/typescript-operations": "^6.0.0",
        "@graphql-codegen/typescript-resolvers": "^6.0.0",
        "@types/jest": "^30.0.0",
        "concurrently": "^8.2.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "typescript-eslint": "^8.59.2"
    },
    "dependencies": {
        "@tailwindcss/typography": "^0.5.19",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-jest-dom": "^5.5.0",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-compiler": "^19.1.0-rc.2",
        "eslint-plugin-testing-library": "^7.16.2",
        "input-otp": "^1.4.2"
    }
}
